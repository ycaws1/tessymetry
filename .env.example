SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# Secret key (sb_secret_...) — Project Settings → API Keys → Secret. Elevated access for this server.
# Legacy name SUPABASE_SERVICE_ROLE_KEY (JWT service_role) still works if you have not migrated.
SUPABASE_SECRET_KEY=

# Not used by this app: Publishable key (sb_publishable_...) is for browsers/clients, like the old anon key.

# Optional: same value as the Authorization header you configure in Teslemetry webhooks
# WEBHOOK_SECRET=

# Comma-separated browser origins for the dashboard API, or * (default)
# CORS_ORIGINS=http://localhost:8000
